    <string>Lafetch uses your location to enhance delivery services, including showing products eligible for quick delivery and optimizing delivery addresses.</string>
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>Lafetch uses your location to show products available for quick delivery within 4 hours and to streamline adding delivery addresses.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>Used to capture audio for image picker</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>To take user profile picture</string>

    <!-- App Transport Security (ATS) Settings -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
