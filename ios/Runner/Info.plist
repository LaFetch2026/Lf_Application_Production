    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>Lafetch requires your location to provide personalized delivery options.</string>

    <key>NSLocationAlwaysUsageDescription</key>
    <string>Lafetch uses your location to enhance delivery services.</string>

